# ──────────────────────────────────────────────────────────────
# 9exp-genesis-lab — Environment variables
# Copy this file to .env.local and fill in real values.
# Never commit .env.local to git.
# ──────────────────────────────────────────────────────────────

# ── NextAuth ──────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET=

# Base URL of the app (used by NextAuth for callbacks)
# Dev: http://localhost:3000
# Prod: https://www.9experttraining.com
AUTH_URL=http://localhost:3000

# ── MongoDB (internal data — admin, banners, articles, registrations) ──
# Pool size is set in src/lib/db/connect.js (maxPoolSize: 5) — that is the
# source of truth. Free Tier (M0) caps the cluster at 500 connections, so we
# keep 5 per serverless instance; bump connect.js to 10-20 after upgrading to
# M10. You can also pin it in the URI below as documentation/belt-and-braces.
MONGODB_URI=mongodb+srv://<user>:<pass>@<cluster>/<dbname>?retryWrites=true&w=majority&maxPoolSize=5
MONGODB_DB_NAME=9exp_genesis

# ── External API (read-only course/schedule/career data) ──────
AI_API_BASE=https://9exp-sec.com/api/ai
AI_API_KEY=

# ── Landing-page cache cron secret ────────────────────────────
# Required by /api/cron/landing-sync (Vercel Cron sends this as
# Authorization: Bearer <CRON_SECRET>). Generate with:
#   openssl rand -base64 32
# When unset (e.g. local dev), the cron route accepts unauthenticated
# GETs so you can hit it from a browser to test. ALWAYS set this in prod.
CRON_SECRET=

# ── Obfuscated admin entry token ──────────────────────────────
# /admin returns 404 for unauthenticated visitors UNLESS they hit it
# with `?knock=<this token>`, which redirects them to /admin/login and
# sets a short-lived cookie so subsequent /admin/login navigations work
# without the token in the URL. This is obfuscation, not security —
# the real auth gate is still NextAuth. Generate with:
#   node -e "console.log(require('crypto').randomBytes(18).toString('base64url'))"
ADMIN_ENTRY_TOKEN=

# ── Cloudinary (image uploads: banners, articles, logos) ──────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_UPLOAD_FOLDER=9exp-genesis

# ── Postmark (transactional email: registration confirmations) ──
POSTMARK_SERVER_TOKEN=
POSTMARK_FROM_EMAIL=no-reply@9experttraining.com
POSTMARK_FROM_NAME=9Expert Training
POSTMARK_ADMIN_EMAIL=pirasak.s@9expert.co.th

# ── Site metadata ─────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME=9Expert Training

# ── Webhook receiver (MSDB → Genesis) ─────────────────────────
# Shared HMAC secret used to verify incoming POSTs at
# /api/webhooks/msdb. MUST equal MSDB's WEBHOOK_DEFAULT_SECRET.
# Generate with:
#   openssl rand -hex 32
MSDB_WEBHOOK_SECRET=

# ── Omise (online card / PromptPay QR payments) ───────────────
# Phase 1: use TEST keys (pkey_test_… / skey_test_…). Swap to live
# keys only at production deploy. Get keys from the Omise dashboard.
#
# NEXT_PUBLIC_OMISE_PUBLIC_KEY is exposed to the browser on purpose —
# Omise.js tokenizes the card client-side so raw card data never hits
# our server. The secret key stays server-only.
OMISE_PUBLIC_KEY=pkey_test_xxxxxxxxxxxxxxxxxxxx
OMISE_SECRET_KEY=skey_test_xxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_OMISE_PUBLIC_KEY=pkey_test_xxxxxxxxxxxxxxxxxxxx
# Shared secret you set when creating the webhook endpoint in Omise.
OMISE_WEBHOOK_SECRET=
#
# Unlocks /api/registration/public/dev-mark-paid to simulate a paid
# webhook (e.g. to complete test-mode PromptPay charges, which Omise
# never auto-completes). The endpoint returns 403 unless this is set to
# exactly "true". See docs/payment-testing.md.
# SECURITY: set only during active test sessions — never leave it on in
# production. Remove it from Vercel env vars when done testing.
# PAYMENT_TEST_MODE=false
#
# Set to 'true' (must match PAYMENT_TEST_MODE) to show the dev pay shortcut
# button in the UI on any environment. Remove after testing.
NEXT_PUBLIC_PAYMENT_TEST_MODE=
