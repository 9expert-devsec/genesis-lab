# ──────────────────────────────────────────────────────────────
# 9exp-genesis-lab — Environment variables
# Copy this file to .env.local and fill in real values.
# Never commit .env.local to git.
# ──────────────────────────────────────────────────────────────

# ── NextAuth ──────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET=

# Base URL of the app (used by NextAuth for callbacks)
# Dev: http://localhost:3000
# Prod: https://www.9experttraining.com
AUTH_URL=http://localhost:3000

# ── MongoDB (internal data — admin, banners, articles, registrations) ──
MONGODB_URI=mongodb+srv://<user>:<pass>@<cluster>/<dbname>?retryWrites=true&w=majority
MONGODB_DB_NAME=9exp_genesis

# ── External API (read-only course/schedule/career data) ──────
AI_API_BASE=https://9exp-sec.com/api/ai
AI_API_KEY=

# ── Cloudinary (image uploads: banners, articles, logos) ──────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_UPLOAD_FOLDER=9exp-genesis

# ── Postmark (transactional email: registration confirmations) ──
POSTMARK_SERVER_TOKEN=
POSTMARK_FROM_EMAIL=no-reply@9experttraining.com
POSTMARK_FROM_NAME=9Expert Training

# ── Site metadata ─────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME=9Expert Training
